NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_EVOLUTION_API_URL=https://your-evolution-api.com
NEXT_PUBLIC_EVOLUTION_API_KEY=your-evolution-api-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# IA interna dos forms
OPENAI_API_KEY=your-openai-api-key
OPENAI_FORM_MODEL=gpt-4.1-mini
# Use um Assistant ID (asst_...) ou um Prompt/Agent ID reutilizavel.
OPENAI_FORM_AGENT_ID=
OPENAI_FORM_PROMPT_ID=
OPENAI_NINA_MODEL=gpt-5.1
OPENAI_NINA_SYSTEM_PROMPT=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret-from-mp-dashboard

# Nota: copie este arquivo para .env.local e preencha com suas credenciais reais
# NUNCA commite o .env.local no git
