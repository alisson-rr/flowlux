    {
      "parameters": {
        "url": "=https://ivlwadsixcetunnhkkam.supabase.co/rest/v1/leads?user_id=eq.{{ $('3. Normalizar Dados').item.json.user_id }}&archived=eq.false&deleted_at=is.null&select=id,name,phone,stage_id,lead_tags(tag_id)",
        "authentication": "predefinedCredentialType",
