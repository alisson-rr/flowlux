    {
      "parameters": {
        "url": "=https://ivlwadsixcetunnhkkam.supabase.co/rest/v1/whatsapp_instances?id=eq.{{ $('3. Normalizar Dados').item.json.instance_id }}&deleted_at=is.null&select=instance_name,status",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "options": {}
      },
      "id": "buscar-inst-01",
      "name": "6. Buscar Instancia",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1900, 340],
      "alwaysOutputData": true,
      "credentials": {
        "supabaseApi": {
          "id": "Pv48djwcm2OcpOqt",
          "name": "FlowLux"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Pega leads do node 5 - pode vir como array dentro de json ou items separados\nconst leadsRaw = $('5. Buscar Leads').all();\nlet allLeads = [];\nfor (const item of leadsRaw) {\n  if (Array.isArray(item.json)) {\n    allLeads = allLeads.concat(item.json);\n  } else if (item.json?.id) {\n    allLeads.push(item.json);\n  }\n}\nif (allLeads.length === 0) return [{json: {error: 'no_leads'}}];\n\n// Pega instancia do node 6\nconst instRaw = $('6. Buscar Instancia').all();\nlet instanceName = '';\nlet instanceStatus = '';\nfor (const item of instRaw) {\n  if (Array.isArray(item.json) && item.json.length > 0) {\n    instanceName = item.json[0].instance_name || '';\n    instanceStatus = item.json[0].status || '';\n  } else if (item.json?.instance_name) {\n    instanceName = item.json.instance_name;\n    instanceStatus = item.json.status || '';\n  }\n}\nif (!instanceName) return [{json: {error: 'no_instance'}}];\nif (instanceStatus !== 'connected') return [{json: {error: 'instance_disconnected', instanceName}}];\n\nconst massData = $('3. Normalizar Dados').first().json;\n\n// Parse filtros de tags e stages\nfunction toArr(v) {\n  if (!v) return [];\n  if (Array.isArray(v)) return v;\n  if (typeof v === 'string') { try { return JSON.parse(v) || []; } catch(e) { return []; } }\n  return [];\n}\nconst targetTags = toArr(massData.target_tags);\nconst targetStages = toArr(massData.target_stages);\n\n// Filtrar leads por tags e/ou stages\nconst filteredLeads = allLeads.filter(lead => {\n  if (!lead || !lead.id) return false;\n  const leadTagIds = (lead.lead_tags || []).map(lt => lt.tag_id);\n  const tagOk = targetTags.length === 0 || targetTags.some(t => leadTagIds.includes(t));\n  const stageOk = targetStages.length === 0 || targetStages.includes(lead.stage_id);\n  return tagOk && stageOk;\n});\n\nif (filteredLeads.length === 0) return [{json: {error: 'no_leads_matched'}}];\n\n// Retorna lista de envio\nreturn filteredLeads.map(lead => {\n  const phone = (lead.phone || '').replace(/\\D/g, '');\n  const number = phone.startsWith('55') ? phone : '55' + phone;\n  return {\n    json: {\n      lead_id: lead.id,\n      lead_name: lead.name,\n      lead_phone: lead.phone,\n      number: number,\n      remoteJid: number + '@s.whatsapp.net',\n      instanceName: instanceName,\n      message: massData.message,\n      mass_id: massData.mass_id,\n      user_id: massData.user_id\n    }\n  };\n});"
      },
