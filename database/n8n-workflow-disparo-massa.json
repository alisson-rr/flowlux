{
  "name": "FlowLux - Disparo em Massa WhatsApp",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Supabase REST API retorna array. O HTTP Request do n8n pode retornar:\n// - Um item com json sendo o array inteiro: [{json: [{...}, {...}]}]\n// - Ou items separados: [{json: {...}}, {json: {...}}]\n\nconst allItems = $input.all();\nlet disparos = [];\n\nfor (const item of allItems) {\n  if (Array.isArray(item.json)) {\n    // Veio como array dentro do json\n    disparos = disparos.concat(item.json);\n  } else if (item.json && item.json.id) {\n    // Veio como item individual\n    disparos.push(item.json);\n  }\n}\n\n// Filtra apenas os que estao scheduled\ndisparos = disparos.filter(d => d.status === 'scheduled' && d.id);\n\nif (disparos.length === 0) {\n  return []; // Para o fluxo - sem disparos\n}\n\n// Retorna cada disparo como um item separado\nreturn disparos.map(d => ({ json: d }));"
      },
