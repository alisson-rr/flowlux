    {
      "parameters": {
        "jsCode": "// === Buscar leads do node 5 ===\nconst leadsRaw = $('5. Buscar Leads').all();\nlet allLeads = [];\nfor (const item of leadsRaw) {\n  if (Array.isArray(item.json)) {\n    allLeads = allLeads.concat(item.json);\n  } else if (item.json && item.json.id) {\n    allLeads.push(item.json);\n  }\n}\nif (allLeads.length === 0) return [{json: {error: 'no_leads'}}];\n\n// === Buscar instancia do node 6 ===\nconst instRaw = $('6. Buscar Instancia').all();\nlet instanceName = '';\nlet instanceStatus = '';\nfor (const item of instRaw) {\n  if (Array.isArray(item.json) && item.json.length > 0) {\n    instanceName = item.json[0].instance_name || '';\n    instanceStatus = item.json[0].status || '';\n  } else if (item.json && item.json.instance_name) {\n    instanceName = item.json.instance_name;\n    instanceStatus = item.json.status || '';\n  }\n}\nif (!instanceName) return [{json: {error: 'no_instance'}}];\nif (instanceStatus !== 'connected') return [{json: {error: 'instance_disconnected'}}];\n\n// === Dados do disparo ===\nconst massData = $('3. Normalizar Dados').first().json;\n\n// === Parse filtros ===\nfunction toArr(v) {\n  if (!v) return [];\n  if (Array.isArray(v)) return v;\n  if (typeof v === 'string') { try { const p = JSON.parse(v); return Array.isArray(p) ? p : []; } catch(e) { return []; } }\n  return [];\n}\nconst targetTags = toArr(massData.target_tags);\nconst targetStages = toArr(massData.target_stages);\n\n// === Filtrar leads ===\nconst filteredLeads = allLeads.filter(lead => {\n  if (!lead || !lead.id) return false;\n  const leadTagIds = (lead.lead_tags || []).map(lt => lt.tag_id);\n  const tagOk = targetTags.length === 0 || targetTags.some(t => leadTagIds.includes(t));\n  const stageOk = targetStages.length === 0 || targetStages.includes(lead.stage_id);\n  return tagOk && stageOk;\n});\n\nif (filteredLeads.length === 0) return [{json: {error: 'no_leads_matched'}}];\n\n// === Montar lista de envio ===\nreturn filteredLeads.map(lead => {\n  let phone = String(lead.phone || '').replace(/\\D/g, '').trim();\n  if (!phone) return null;\n  if (phone.startsWith('00')) phone = phone.slice(2);\n  if (!phone.startsWith('55')) {\n    if (phone.length === 11 || phone.length === 10) {\n      phone = '55' + phone;\n    } else {\n      return null;\n    }\n  }\n  return {\n    json: {\n      lead_id: lead.id,\n      lead_name: lead.name,\n      lead_phone: lead.phone,\n      number: phone,\n      remoteJid: phone + '@s.whatsapp.net',\n      instanceName: instanceName.trim(),\n      message: (massData.message || '').trim(),\n      mass_id: massData.mass_id,\n      user_id: massData.user_id\n    }\n  };\n}).filter(Boolean);"
      },
